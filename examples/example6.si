val make_obs1 = fun (obs, x_pre) -> let rv3 = Prob.new_var() in let () = Prob.set_distr(rv3,gaussian(x_pre,1.0)) in let () = Prob.set_lookup("x",rv3) in let x = rv3 in let rv5 = Prob.new_var() in let () = Prob.set_distr(rv5,gaussian(x,1.0)) in let () = Prob.set_distr(rv5,gaussian(Prob.get_mu(Prob.get_distr(rv5)),Prob.get_var(Prob.get_distr(rv5)))) in let () = Prob.set_distr(rv5,gaussian(Prob.get_mu(Prob.get_distr(rv5)),Prob.get_var(Prob.get_distr(rv5)))) in let () = Prob.set_distr(Prob.get_par(Prob.get_par(rv5,0),0),gaussian((Prob.get_par(rv5,0) * 0.9900990099009901), 0.9900990099009901)) in let () = Prob.set_distr(Prob.get_par(rv5,0),gaussian(0.0, 101.0)) in let () = Prob.set_distr(Prob.get_par(rv5,0),gaussian((rv5 * 0.9901960784313726), 0.9901960784313726)) in let () = Prob.set_distr(rv5,gaussian(0.0, 102.0)) in let () = Prob.observe_inner(rv5,obs) in let () = Prob.null() in x in let data = [1.0, 3.0] in let rv1 = Prob.new_var() in let () = Prob.set_distr(rv1,gaussian(0.0,100.0)) in let () = Prob.set_lookup("x_init",rv1) in let x_init = rv1 in let xs = fold(make_obs1, data, x_init) in Prob.finalize(xs)